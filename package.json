{
  "name": "sniff-qa",
  "version": "0.1.0",
  "description": "AI powered autonomous QA testing. Scan, explore, and report bugs before users do. One command. Five checks. Zero config.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "sniff": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "testing", "qa", "playwright", "accessibility", "e2e",
    "ai", "claude", "visual-regression", "ci", "automation",
    "a11y", "performance", "mcp"
  ],
  "author": "Adam Boudj <adam@integralayer.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Aboudjem/sniff#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aboudjem/sniff.git"
  },
  "bugs": {
    "url": "https://github.com/Aboudjem/sniff/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@axe-core/playwright": "^4.11.1",
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vue/compiler-sfc": "^3.5.32",
    "chrome-launcher": "^1.2.1",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.1",
    "fast-glob": "^3.3.3",
    "lighthouse": "^13.1.0",
    "picocolors": "^1.1.1",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^25.6.0",
    "@types/pngjs": "^6.0.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
